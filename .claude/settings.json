{
  "permissions": {
    "deny": [
      "Edit .env",
      "Write .env",
      "Bash rm -rf"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "test -f .env || echo 'WARNING: .env file not found. Copy .env.example to .env and fill in credentials.'"
          }
        ]
      }
    ]
  }
}
